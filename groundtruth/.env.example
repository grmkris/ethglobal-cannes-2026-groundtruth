# Ground Truth — environment variables
# Validated at build time by src/env.ts. Every value below is REQUIRED.

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/groundtruth

# --- Better Auth (SIWE) ---
# 32+ byte random secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
# SIWE domain. Localhost in dev, your public host in prod.
AUTH_DOMAIN=localhost:3000

# --- World ID 4.0 ---
# Get these from https://developer.world.org
WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RP ID must start with `rp_`
WORLD_RP_ID=rp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORLD_SIGNING_KEY=replace-me

# --- Vercel Blob (image uploads) ---
# Create a Blob store at https://vercel.com/dashboard/stores and copy the token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# --- Runtime ---
NODE_ENV=development
# Public URL of this app — used as the agent card base URL
APP_URL=http://localhost:3000

# --- Web3 RPC ---
# Mainnet RPC used by the server for ERC-8004 contract reads. ENS resolution
# now goes through Reown's Identity API (no Infura roundtrip needed).
# Get a project ID at https://app.infura.io
INFURA_PROJECT_ID=replace-me

# --- x402 / Arc nanopayments ---
# EVM address that receives paid-read nanopayments on Arc Testnet
AGENT_PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000

# --- Client-side (NEXT_PUBLIC_*) ---
# Reown / WalletConnect Cloud project ID — https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=replace-me
# Same World ID app ID. Must start with `app_`.
NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
